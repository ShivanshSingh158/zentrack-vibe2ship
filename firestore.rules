rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Null-safe ownership check for existing documents.
    // resource.data.get('userId', null) prevents null-dereference when a field is missing.
    function ownsDoc() {
      return resource != null
        && resource.data.get('userId', null) == request.auth.uid;
    }

    // Ownership check for documents being created.
    function ownsNewDoc() {
      return request.resource.data.get('userId', null) == request.auth.uid;
    }

    // Prevent oversized document writes (basic DoS protection — 50 fields max).
    function notTooLarge() {
      return request.resource.data.size() < 50;
    }

    // ── Users Collection ──────────────────────────────────────────────────────
    // Secure against self-elevation (isAdmin field cannot be set by the user).
    match /users/{userId} {
      allow read: if isSignedIn() && isOwner(userId);

      // Allow profile creation on first login, but never with isAdmin: true
      allow create: if isSignedIn()
        && isOwner(userId)
        && request.resource.data.userId == userId
        && (!request.resource.data.keys().hasAll(['isAdmin'])
            || request.resource.data.isAdmin == false);

      // Allow profile updates, but CANNOT modify or add the isAdmin field
      allow update: if isSignedIn()
        && isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);

      // User profiles are never deleted from the client
      allow delete: if false;
    }

    // ── Generic User-Scoped Collections ───────────────────────────────────────
    // Covers: todos, habits, habit_logs, notes, goals, job_applications,
    //         daily_logs, learning_topics, attendance_subjects, assignments,
    //         pomodoro_sessions, and any other userId-keyed collection.
    // Explicitly excluded: users, fcm_tokens, notification_throttle, rate_limits
    match /{collection}/{docId} {
      allow read, update, delete: if isSignedIn()
        && collection != 'users'
        && collection != 'fcm_tokens'
        && collection != 'notification_throttle'
        && collection != 'rate_limits'
        && ownsDoc();

      allow create: if isSignedIn()
        && collection != 'users'
        && collection != 'fcm_tokens'
        && collection != 'notification_throttle'
        && collection != 'rate_limits'
        && ownsNewDoc()
        && notTooLarge();
    }

    // ── FCM Tokens (docId = userId) ───────────────────────────────────────────
    // Only the owning user manages their own FCM token from the client.
    // Server (Admin SDK) bypasses rules to scan all tokens in cron-watchdog.
    match /fcm_tokens/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── User Behavior Profiles ────────────────────────────────────────────────
    // Written by patternEngine.ts saveBehaviorProfile().
    match /user_profiles/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Gym Logs ──────────────────────────────────────────────────────────────
    match /gymLogs/{docId} {
      allow read, update, delete: if isSignedIn() && ownsDoc();
      allow create: if isSignedIn() && ownsNewDoc() && notTooLarge();
    }

    // ── Weekly Reviews ────────────────────────────────────────────────────────
    match /weekly_reviews/{docId} {
      allow read, update, delete: if isSignedIn() && ownsDoc();
      allow create: if isSignedIn() && ownsNewDoc() && notTooLarge();
    }

    // ── Agent Long-Term Memory (subcollection) ────────────────────────────────
    // agent_memory/{userId}/interactions/{entryId}
    match /agent_memory/{userId}/interactions/{entryId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Generated Scripts ─────────────────────────────────────────────────────
    // Written by toolExecutor.ts (HEPHAESTUS agent).
    match /generated_scripts/{docId} {
      allow read, update, delete: if isSignedIn() && ownsDoc();
      allow create: if isSignedIn() && ownsNewDoc() && notTooLarge();
    }

    // ── Lecture Chat History (subcollection) ──────────────────────────────────
    // lectureChats/{userId}/videos/{videoId}
    match /lectureChats/{userId}/videos/{videoId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Notification History (subcollection) ─────────────────────────────────
    // notifications/{userId}/history/{entryId}
    match /notifications/{userId}/history/{entryId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Push Notification Queue ───────────────────────────────────────────────
    // Client can ONLY create items targeting themselves.
    // Read/update/delete is Admin SDK only (cron-queue-processor.js).
    match /pushNotificationQueue/{docId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['userIds', 'title', 'body', 'url', 'tag', 'status', 'createdAt'])
        && request.auth.uid in request.resource.data.userIds;
      allow read, update, delete: if false; // Admin SDK only
    }

    // ── Scheduled Reminders ───────────────────────────────────────────────────
    match /scheduledReminders/{docId} {
      allow create: if isSignedIn() && ownsNewDoc();
      allow read, update, delete: if isSignedIn() && ownsDoc();
    }

    // ── Rate Limits ───────────────────────────────────────────────────────────
    // Written by api/gemini-proxy.js (Admin SDK — bypasses rules).
    // NO client access at all.
    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    // ── Notification Throttle ─────────────────────────────────────────────────
    // Written by cron-watchdog.js and cron-classes.js (Admin SDK).
    // NO client access at all.
    match /notification_throttle/{docId} {
      allow read, write: if false;
    }

    // ── Deny Everything Else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

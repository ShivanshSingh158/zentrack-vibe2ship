rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ── User-scoped collections (userId field pattern) ────────────────────────

    // todos, habits, habit_logs, notes, goals, job_applications, daily_logs,
    // learning_topics, attendance_subjects, assignments, todos
    match /{collection}/{docId} {
      allow read, write: if isSignedIn()
        && collection != 'users'
        && resource != null
        && isOwner(resource.data.userId);

      allow create: if isSignedIn()
        && collection != 'users'
        && isOwner(request.resource.data.userId);
    }

    // ── Users Collection (Secure against self-elevation) ──────────────────────
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isSignedIn() && isOwner(userId);
      
      // Users can create their own profile (e.g. on first login), but cannot set isAdmin: true
      allow create: if isSignedIn() 
        && isOwner(userId) 
        && request.resource.data.userId == userId
        && (!request.resource.data.keys().hasAll(['isAdmin']) || request.resource.data.isAdmin == false);
      
      // Users can update their profile, but CANNOT modify or add the isAdmin field
      allow update: if isSignedIn() 
        && isOwner(userId) 
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']));
    }

    // ── FCM Tokens (docId = userId) ───────────────────────────────────────────
    // Only the owning user can read/write their own FCM token.
    // Server (Admin SDK) bypasses rules — so send-notification.js still works.
    match /fcm_tokens/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Gym Logs (docId = userId_date) ───────────────────────────────────────
    match /gymLogs/{docId} {
      allow read, write: if isSignedIn()
        && resource != null
        && isOwner(resource.data.userId);

      allow create: if isSignedIn()
        && isOwner(request.resource.data.userId);
    }

    // ── Weekly Reviews ────────────────────────────────────────────────────────
    match /weekly_reviews/{docId} {
      allow read, write: if isSignedIn()
        && resource != null
        && isOwner(resource.data.userId);

      allow create: if isSignedIn()
        && isOwner(request.resource.data.userId);
    }

    // ── User Behavior Profiles (MED-5 FIX) ───────────────────────────────────
    // Stores behavioral learning data: peak hours, persona, completion ratio, etc.
    // Written by patternEngine.ts saveBehaviorProfile() → MUST be allowed or
    // the entire UserLearningStore silently fails to persist across sessions.
    match /user_profiles/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Agent Long-Term Memory (MED-6 FIX) ───────────────────────────────────
    // Subcollection: agent_memory/{userId}/interactions/{entryId}
    // Written by agentMemoryPersistence.ts recordMemory().
    // Without this rule, approval history, ghost task dedup, and email memory
    // silently fail — agents lose cross-session learning every page reload.
    match /agent_memory/{userId}/interactions/{entryId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Generated Scripts (MED-7 FIX) ────────────────────────────────────────
    // Written by toolExecutor.ts case 'generate_script' (HEPHAESTUS agent).
    // Without this rule, every HEPHAESTUS script persists to Firestore silently fails.
    match /generated_scripts/{docId} {
      allow read, write: if isSignedIn()
        && resource != null
        && isOwner(resource.data.userId);

      allow create: if isSignedIn()
        && isOwner(request.resource.data.userId);
    }

    // ── Lecture Chat History (subcollection path) ─────────────────────────────
    // lectureChats/{userId}/videos/{videoId}
    // Each user can only access their own chat history.
    match /lectureChats/{userId}/videos/{videoId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Push Notifications Queue ──────────────────────────────────────────────
    // Users can only queue notifications targeting themselves.
    match /pushNotificationQueue/{docId} {
      allow create: if isSignedIn() 
        && request.resource.data.keys().hasOnly(['userIds', 'title', 'body', 'url', 'tag', 'status', 'createdAt'])
        && request.auth.uid in request.resource.data.userIds; // Can only target yourself
      allow read, update, delete: if false; // Admin SDK only
    }

    // ── Scheduled Reminders ───────────────────────────────────────────────────
    match /scheduledReminders/{docId} {
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow update: if isSignedIn() && isOwner(resource.data.userId);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // ── Notification History (FEAT-7) ─────────────────────────────────────────
    // Subcollection: notifications/{userId}/history/{entryId}
    // Written by toolExecutor.ts send_notification case (non-blocking fire-and-forget).
    // Enables a notification history panel so users can review past agent alerts.
    match /notifications/{userId}/history/{entryId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
